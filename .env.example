# Server
PORT=8080
HTTPS_PORT=8443
NODE_ENV=development
DATA_DIR=

# Optional hardening.
# When ADMIN_TOKEN is set, mutating API calls require:
#   Authorization: Bearer <token>
# or:
#   X-Admin-Token: <token>
ADMIN_TOKEN=

# Comma-separated browser origins allowed for HTTP API and WebSocket CORS.
# Leave empty for local/prototype use.
ALLOWED_ORIGINS=

# Maximum inbound WebSocket payload size in bytes.
MAX_WS_MESSAGE_BYTES=65536

# Optional legacy local tunnel publishing used by 启动计时系统.bat.
GITHUB_TOKEN=
GIST_ID=
